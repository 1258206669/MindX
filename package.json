{
  "name": "multi-agent-cli",
  "version": "0.1.0",
  "description": "Multi-agent CLI framework — supports LLM and local CLI tool backends with memory",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "macli": "dist/index.js"
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean",
    "dev": "node --import tsx src/index.ts",
    "start": "node dist/index.js"
  },
  "dependencies": {
    "express": "^4.21.0",
    "sql.js": "^1.11.0",
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "eventemitter3": "^5.0.1",
    "glob": "^11.0.0",
    "ink": "^5.1.0",
    "ink-text-input": "^6.0.0",
    "react": "^18.3.1",
    "uuid": "^10.0.0",
    "ws": "^8.18.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@anthropic-ai/sdk": "^0.52.0",
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.0",
    "@types/react": "^18.3.0",
    "@types/uuid": "^10.0.0",
    "@types/ws": "^8.5.0",
    "tsup": "^8.3.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}
